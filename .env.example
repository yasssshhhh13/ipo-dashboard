# Copy to .env.local for local testing (never commit real secrets).
# Get this from Google Analytics → Admin → Data streams → your web stream.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Absolute site origin for canonical URLs, Open Graph, and sitemap (no trailing slash).
# Set the same value in Vercel → Environment Variables for Production builds.
VITE_SITE_URL=https://calmcapital.in

# Server-only (Vercel). Not used by Vite client.
# ANTHROPIC_API_KEY=
