# Copy to .env.local for local development. Never commit real secrets.
# Vite only embeds variables prefixed with VITE_ into the browser bundle.
# Server-only vars (no VITE_ prefix) are read by Vercel serverless functions.

# --- Client / build (public — safe to expose in the browser) ---
# Google Analytics 4 Measurement ID (not a secret; still keep in env for rotation).
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Absolute site origin for canonical URLs, Open Graph, and sitemap (no trailing slash).
VITE_SITE_URL=https://example.com

# --- Server only (Vercel Environment Variables — never use a VITE_ / NEXT_PUBLIC_ / REACT_APP_ prefix) ---
# Anthropic API key for /api/chat. Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
